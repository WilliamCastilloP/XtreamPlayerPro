# Optional: media proxy with MKV→HLS (Netflix-like playback).
# Run: npm run proxy  (requires ffmpeg on PATH)
# Then set this and restart next / redeploy Vercel:
#
# Local proxy:
# NEXT_PUBLIC_STREAM_PROXY_BASE=http://127.0.0.1:8080
#
# Oracle / VPS (HTTPS):
# NEXT_PUBLIC_STREAM_PROXY_BASE=https://proxy.example.com
#
# See docs/self-hosted-proxy.md
NEXT_PUBLIC_STREAM_PROXY_BASE=

# Local/dev Connect button (create `.env.local`, then restart npm run dev):
XTREAM_DEV_NAME=My playlist
XTREAM_DEV_SERVER=https://example.com:8080
XTREAM_DEV_USERNAME=user
XTREAM_DEV_PASSWORD=pass
#
# If login fails with a TLS/certificate error against your Xtream panel:
#   PowerShell:  $env:NODE_TLS_REJECT_UNAUTHORIZED=0; npm run dev
#   macOS/Linux: NODE_TLS_REJECT_UNAUTHORIZED=0 npm run dev
