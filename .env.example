# Optional: move heavy video traffic off Vercel onto a self-hosted proxy.
# Leave empty to keep using same-origin /api/stream (default).
#
# Example (after you run scripts/stream-proxy.mjs behind HTTPS):
# NEXT_PUBLIC_STREAM_PROXY_BASE=https://proxy.example.com
#
# See docs/self-hosted-proxy.md for the full setup plan (Oracle / Hetzner /
# Cloudflare Tunnel).
NEXT_PUBLIC_STREAM_PROXY_BASE=

# Local/dev only: set to 1 if login fails with a TLS/certificate error
# against your Xtream panel (common with self-signed HTTPS panels).
# XTREAM_INSECURE_TLS=1
